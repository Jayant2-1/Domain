# ── Application ─────────────────────────────────────────────
APP_PORT=8000
MLML_DB_PATH=data/mlml.db
MLML_MODEL_ID=TinyLlama/TinyLlama-1.1B-Chat-v1.0
MLML_FAISS_INDEX_DIR=faiss_index
MLML_ADAPTER_DIR=
MLML_LOG_LEVEL=info
MLML_MAX_NEW_TOKENS=512
MLML_INFERENCE_TIMEOUT=60.0
MLML_RAG_TOP_K=3
MLML_RAG_SCORE_THRESHOLD=0.3

# ── MongoDB ─────────────────────────────────────────────────
MONGO_USER=mlml
MONGO_PASS=mlml_secret
MONGO_PORT=27017
MLML_MONGODB_URI=mongodb://mlml:mlml_secret@localhost:27017
MLML_MONGODB_DB=mlml

# ── Auth / JWT ──────────────────────────────────────────────
MLML_JWT_SECRET=change-me-in-production

# ── Security ────────────────────────────────────────────────
MLML_API_KEY=
MLML_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
